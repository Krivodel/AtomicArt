{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "GoogleInteractions": {
    "TimeoutSeconds": 900,
    "MaxRequestBytes": 838860800,
    "MaxResponseBytes": 1073741824,
    "MaxAnalyzedMetadataBytes": 4194304,
    "MaxResponseStructureDepth": 64,
    "MaxDiagnosticTextCharacters": 512
  },
  "Generation": {
    "MaxConcurrentGenerations": 64
  },
  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 1073741824
    }
  },
  "TestGeneration": {
    "Enabled": false,
    "ImagesDirectory": "TestGenerationImages"
  },
  "AllowedHosts": "*"
}
