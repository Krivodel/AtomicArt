<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:suki="using:SukiUI"
             x:Class="AtomicArt.Desktop.App"
             RequestedThemeVariant="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <MergeResourceInclude Source="avares://AtomicArt/Resources/Colors.axaml" />
                <MergeResourceInclude Source="avares://AtomicArt/Resources/Dimensions.axaml" />
                <MergeResourceInclude Source="avares://AtomicArt/Resources/Icons.axaml" />
                <MergeResourceInclude Source="avares://AtomicArt/Resources/Converters.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <suki:SukiTheme ThemeColor="Blue" />
        <StyleInclude Source="avares://AtomicArt/Resources/ComboBoxStyles.axaml" />
        <StyleInclude Source="avares://AtomicArt/Resources/TextStyles.axaml" />
        <StyleInclude Source="avares://AtomicArt/Resources/ButtonStyles.axaml" />
        <StyleInclude Source="avares://AtomicArt/Resources/ScrollViewerStyles.axaml" />
        <StyleInclude Source="avares://AtomicArt/Resources/Templates.axaml" />
    </Application.Styles>
</Application>
