<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <BoxShadows x:Key="FloatingSurfaceShadow">0 18 42 0 #80000000</BoxShadows>
    <SolidColorBrush x:Key="GlassCardBrush"
                     Color="{DynamicResource SukiGlassCardBackground}"
                     Opacity="{DynamicResource GlassOpacity}" />
    <SolidColorBrush x:Key="ModalOverlayTintBrush"
                     Color="{DynamicResource SukiPopupBackground}"
                     Opacity="{DynamicResource ModalOverlayTintOpacity}" />
    <SolidColorBrush x:Key="MetadataBorderBrush"
                     Color="{DynamicResource SukiMenuBorderBrush}"
                     Opacity="0.5" />
    <SolidColorBrush x:Key="MetadataMutedTextBrush"
                     Color="{DynamicResource SukiText}"
                     Opacity="0.62" />
</ResourceDictionary>
