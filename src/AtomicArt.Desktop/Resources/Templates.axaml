<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="Border.shell-section">
        <Setter Property="Padding"
                Value="{StaticResource ShellSectionPadding}" />
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource SukiGlassCardBackground}"
                                 Opacity="{DynamicResource GlassOpacity}" />
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush"
                Value="{DynamicResource GlassBorderBrush}" />
        <Setter Property="BorderThickness"
                Value="{StaticResource ShellBorderThickness}" />
        <Setter Property="CornerRadius"
                Value="{StaticResource ShellCornerRadius}" />
    </Style>

    <Style Selector="Border.generation-panel">
        <Setter Property="Padding"
                Value="{StaticResource GenerationPanelPadding}" />
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource SukiGlassCardBackground}"
                                 Opacity="{DynamicResource GlassOpacity}" />
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush"
                Value="{DynamicResource GlassBorderBrush}" />
        <Setter Property="BorderThickness"
                Value="{StaticResource ShellBorderThickness}" />
        <Setter Property="CornerRadius"
                Value="{StaticResource ShellCornerRadius}" />
    </Style>

    <Style Selector="Border.overlay-panel">
        <Setter Property="Padding"
                Value="{StaticResource OverlayPadding}" />
        <Setter Property="Background"
                Value="{DynamicResource SukiGlassCardOpaqueBackground}" />
        <Setter Property="BorderBrush"
                Value="{DynamicResource GlassBorderBrush}" />
        <Setter Property="BorderThickness"
                Value="{StaticResource ShellBorderThickness}" />
        <Setter Property="CornerRadius"
                Value="{StaticResource OverlayCornerRadius}" />
    </Style>

    <Style Selector=":is(Border).modal-glass-panel">
        <Setter Property="Padding"
                Value="0" />
        <Setter Property="Background"
                Value="{DynamicResource SukiPopupBackground}" />
        <Setter Property="BorderBrush"
                Value="{DynamicResource SukiMenuBorderBrush}" />
        <Setter Property="BoxShadow"
                Value="{DynamicResource SukiPopupShadow}" />
        <Setter Property="ClipToBounds"
                Value="True" />
    </Style>

    <Style Selector="Border.modal-popup-layer">
        <Setter Property="Padding"
                Value="{StaticResource OverlayPadding}" />
        <Setter Property="Background"
                Value="{DynamicResource PopupGradientBrush}" />
    </Style>

    <Style Selector="Border.attachment-preview">
        <Setter Property="Width"
                Value="{StaticResource AttachmentPreviewSize}" />
        <Setter Property="Height"
                Value="{StaticResource AttachmentPreviewSize}" />
        <Setter Property="Margin"
                Value="{StaticResource AttachmentPreviewMargin}" />
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource SukiGlassCardBackground}"
                                 Opacity="{DynamicResource GlassOpacity}" />
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness"
                Value="{StaticResource ZeroThickness}" />
        <Setter Property="ClipToBounds"
                Value="True" />
        <Setter Property="CornerRadius"
                Value="{StaticResource AttachmentPreviewCornerRadius}" />
    </Style>

    <Style Selector="Border.generation-card">
        <Setter Property="Width"
                Value="{StaticResource GenerationCardWidth}" />
        <Setter Property="Height"
                Value="{StaticResource GenerationCardHeight}" />
        <Setter Property="Margin"
                Value="{StaticResource GalleryCardMargin}" />
        <Setter Property="Padding"
                Value="{StaticResource GalleryCardPadding}" />
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource SukiGlassCardBackground}"
                                 Opacity="{DynamicResource GlassOpacity}" />
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness"
                Value="{StaticResource ZeroThickness}" />
        <Setter Property="ClipToBounds"
                Value="False" />
        <Setter Property="CornerRadius"
                Value="{StaticResource GenerationCardCornerRadius}" />
    </Style>

    <Style Selector="Border.image-preview-shadow">
        <Setter Property="BoxShadow"
                Value="0 18 42 0 #80000000" />
    </Style>

    <Style Selector="Border.generation-card-preview">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource SukiGlassCardBackground}"
                                 Opacity="{DynamicResource GlassOpacity}" />
            </Setter.Value>
        </Setter>
        <Setter Property="ClipToBounds"
                Value="True" />
    </Style>

    <Style Selector="Border.generation-card-loading">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush EndPoint="100%,100%"
                                     StartPoint="0%,0%">
                    <GradientStop Color="{DynamicResource SukiPrimaryColor4}"
                                  Offset="0" />
                    <GradientStop Color="{DynamicResource SukiAccentColor}"
                                  Offset="0.45" />
                    <GradientStop Color="{DynamicResource SukiPrimaryColor3}"
                                  Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Opacity"
                Value="0.7" />
        <Style.Animations>
            <Animation Duration="0:0:1.6"
                       IterationCount="Infinite">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity"
                            Value="0.55" />
                </KeyFrame>
                <KeyFrame Cue="50%">
                    <Setter Property="Opacity"
                            Value="1" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity"
                            Value="0.55" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Border.generation-card-empty">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource SukiGlassCardBackground}"
                                 Opacity="{DynamicResource GlassOpacity}" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Border.generation-card-error">
        <Setter Property="HorizontalAlignment"
                Value="Stretch" />
        <Setter Property="VerticalAlignment"
                Value="Stretch" />
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource SukiDangerColor}" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Border.generation-card-info">
        <Setter Property="Padding"
                Value="{StaticResource GalleryCardInfoPadding}" />
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource SukiGlassCardBackground}"
                                 Opacity="{DynamicResource GlassOpacity}" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Image.generation-card-image">
        <Setter Property="Stretch"
                Value="UniformToFill" />
    </Style>
</Styles>
