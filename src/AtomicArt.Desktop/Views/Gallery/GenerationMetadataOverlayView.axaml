<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:gallery="using:AtomicArt.Desktop.ViewModels.Gallery"
             xmlns:resources="using:AtomicArt.Desktop.Resources"
             x:Class="AtomicArt.Desktop.Views.Gallery.GenerationMetadataOverlayView"
             x:DataType="gallery:GenerationMetadataViewModel">
    <Border MaxWidth="{StaticResource MetadataOverlayWidth}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Classes="overlay-panel metadata-panel modal-glass-panel">
        <Border Classes="modal-popup-layer">
            <Grid RowDefinitions="Auto,*">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Classes="overlay-title"
                               Text="{x:Static resources:UiStrings.MetadataTitle}" />
                    <Button Grid.Column="1"
                            Classes="Icon close-action"
                            Command="{Binding CloseCommand}">
                        <PathIcon Data="{StaticResource AppCloseIcon}" />
                    </Button>
                </Grid>

                <Grid Grid.Row="1"
                      Margin="{StaticResource MetadataGridMargin}"
                      ColumnDefinitions="Auto,*"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Classes="metadata-label"
                               Text="{x:Static resources:UiStrings.MetadataCreatedAt}" />
                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               Classes="metadata-value"
                               Text="{Binding CreatedAtUtc}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Classes="metadata-label"
                               Text="{x:Static resources:UiStrings.MetadataModel}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Classes="metadata-value"
                               Text="{Binding ModelDisplayName}" />
                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Classes="metadata-label"
                               Text="{x:Static resources:UiStrings.MetadataResolution}" />
                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Classes="metadata-value"
                               Text="{Binding Resolution}" />
                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Classes="metadata-label"
                               Text="{x:Static resources:UiStrings.MetadataAspectRatio}" />
                    <TextBlock Grid.Row="3"
                               Grid.Column="1"
                               Classes="metadata-value"
                               Text="{Binding AspectRatio}" />
                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Classes="metadata-label"
                               Text="{x:Static resources:UiStrings.MetadataAttachments}" />
                    <TextBlock Grid.Row="4"
                               Grid.Column="1"
                               Classes="metadata-value"
                               Text="{Binding AttachedImagesCount}" />
                    <TextBlock Grid.Row="5"
                               Grid.Column="0"
                               Classes="metadata-label"
                               Text="{x:Static resources:UiStrings.MetadataPrice}" />
                    <TextBlock Grid.Row="5"
                               Grid.Column="1"
                               Classes="metadata-value"
                               Text="{Binding Price}" />
                    <TextBlock Grid.Row="6"
                               Grid.Column="0"
                               Classes="metadata-label"
                               Text="{x:Static resources:UiStrings.MetadataGenerationDuration}" />
                    <TextBlock Grid.Row="6"
                               Grid.Column="1"
                               Classes="metadata-value"
                               Text="{Binding GenerationDuration}" />
                    <TextBlock Grid.Row="7"
                               Grid.Column="0"
                               Classes="metadata-label"
                               Text="{x:Static resources:UiStrings.MetadataStatus}" />
                    <TextBlock Grid.Row="7"
                               Grid.Column="1"
                               Classes="metadata-value"
                               Text="{Binding Status}" />
                    <TextBlock Grid.Row="8"
                               Grid.Column="0"
                               Classes="metadata-label"
                               Text="{x:Static resources:UiStrings.MetadataImagePath}" />
                    <TextBlock Grid.Row="8"
                               Grid.Column="1"
                               Classes="metadata-value"
                               Text="{Binding ImagePath}" />
                    <TextBlock Grid.Row="9"
                               Grid.Column="0"
                               Classes="metadata-label"
                               Text="{x:Static resources:UiStrings.MetadataPrompt}" />
                    <TextBlock Grid.Row="9"
                               Grid.Column="1"
                               Classes="metadata-value"
                               Text="{Binding Prompt}" />
                </Grid>
            </Grid>
        </Border>
    </Border>
</UserControl>
