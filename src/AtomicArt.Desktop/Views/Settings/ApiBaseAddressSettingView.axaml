<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AtomicArt.Desktop.Controls.Settings"
             xmlns:settings="using:AtomicArt.Desktop.ViewModels.Settings"
             x:Class="AtomicArt.Desktop.Views.Settings.ApiBaseAddressSettingView"
             x:DataType="settings:ApiBaseAddressSettingViewModel">
    <controls:SettingItemControl ActionText="{Binding SaveButtonText}"
                                 DisplayName="{Binding DisplayName}"
                                 ErrorMessage="{Binding ErrorMessage}"
                                 HasErrorMessage="{Binding HasErrorMessage}"
                                 ActionCommand="{Binding SaveCommand}">
        <controls:SettingItemControl.Editor>
            <TextBox PlaceholderText="{Binding Placeholder}"
                     Text="{Binding Value, Mode=TwoWay}" />
        </controls:SettingItemControl.Editor>
    </controls:SettingItemControl>
</UserControl>
