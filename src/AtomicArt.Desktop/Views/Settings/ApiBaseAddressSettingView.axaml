<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:settings="using:AtomicArt.Desktop.ViewModels.Settings"
             x:Class="AtomicArt.Desktop.Views.Settings.ApiBaseAddressSettingView"
             x:DataType="settings:ApiBaseAddressSettingViewModel">
    <Grid RowDefinitions="Auto,Auto"
          ColumnDefinitions="*,Auto">
        <StackPanel>
            <TextBlock Classes="metadata-label"
                       Text="{Binding DisplayName}" />
            <TextBox PlaceholderText="{Binding Placeholder}"
                     Text="{Binding Value, Mode=TwoWay}" />
        </StackPanel>
        <Button Grid.Column="1"
                Margin="{StaticResource SettingsActionButtonMargin}"
                VerticalAlignment="Bottom"
                Content="{Binding SaveButtonText}"
                Command="{Binding SaveCommand}" />
        <TextBlock Grid.Row="1"
                   Grid.ColumnSpan="2"
                   Classes="metadata-value"
                   IsVisible="{Binding HasErrorMessage}"
                   Text="{Binding ErrorMessage}" />
    </Grid>
</UserControl>
