<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AtomicArt.Desktop.Controls.Settings"
             xmlns:settings="using:AtomicArt.Desktop.ViewModels.Settings"
             x:Class="AtomicArt.Desktop.Views.Settings.SecretSettingView"
             x:DataType="settings:SecretSettingViewModel">
    <controls:SettingItemControl>
        <controls:SettingItemControl.Editor>
            <TextBox PasswordChar="*"
                     PlaceholderText="{Binding Placeholder}"
                     Text="{Binding Value, Mode=TwoWay}" />
        </controls:SettingItemControl.Editor>
    </controls:SettingItemControl>
</UserControl>
