<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AtomicArt.Desktop.Controls.Settings"
             xmlns:models="using:AtomicArt.Desktop.Models"
             xmlns:settings="using:AtomicArt.Desktop.ViewModels.Settings"
             x:Class="AtomicArt.Desktop.Views.Settings.ScaleSettingView"
             x:DataType="settings:ScaleSettingViewModel">
    <controls:SettingItemControl ActionText="{Binding ApplyButtonText}"
                                 DisplayName="{Binding DisplayName}"
                                 ErrorMessage="{Binding ErrorMessage}"
                                 HasErrorMessage="{Binding HasErrorMessage}"
                                 ActionCommand="{Binding ApplyCommand}">
        <controls:SettingItemControl.Editor>
            <ComboBox ItemsSource="{Binding Options}"
                      SelectedItem="{Binding SelectedOption, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="models:UiScaleOption">
                        <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </controls:SettingItemControl.Editor>
    </controls:SettingItemControl>
</UserControl>
