<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AtomicArt.Desktop.Controls.Overlays"
             xmlns:resources="using:AtomicArt.Desktop.Resources"
             xmlns:settings="using:AtomicArt.Desktop.ViewModels.Settings"
             x:Class="AtomicArt.Desktop.Views.Settings.SettingsOverlayView"
             x:DataType="settings:SettingsViewModel">
    <controls:ModalOverlayControl MaxWidth="{StaticResource SettingsOverlayWidth}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Top"
                                  Title="{x:Static resources:UiStrings.SettingsTitle}"
                                  CloseCommand="{Binding CloseCommand}">
        <controls:ModalOverlayControl.Body>
            <ItemsControl Margin="{StaticResource SettingsSectionMargin}"
                          ItemsSource="{Binding Settings}" />
        </controls:ModalOverlayControl.Body>
    </controls:ModalOverlayControl>
</UserControl>
