<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AtomicArt.Desktop.Controls.Generation"
             xmlns:overlays="using:AtomicArt.Desktop.Controls.Overlays"
             xmlns:resources="using:AtomicArt.Desktop.Resources"
             xmlns:system="using:System"
             x:Class="AtomicArt.Desktop.Controls.Generation.ImageDropOverlayControl"
             x:Name="Root"
             x:DataType="controls:ImageDropOverlayControl"
             ClipToBounds="True"
             IsHitTestVisible="False">
    <UserControl.Resources>
        <system:TimeSpan x:Key="ImageDropOverlayFadeDuration">0:0:0.18</system:TimeSpan>
        <CubicEaseOut x:Key="ImageDropOverlayEasing" />
    </UserControl.Resources>

    <Grid>
        <Grid x:Name="OverlayChrome"
              Opacity="0">
            <Grid.Transitions>
                <Transitions>
                    <DoubleTransition Duration="{StaticResource ImageDropOverlayFadeDuration}"
                                      Easing="{StaticResource ImageDropOverlayEasing}"
                                      Property="Opacity" />
                </Transitions>
            </Grid.Transitions>

            <Border ClipToBounds="True"
                    CornerRadius="{Binding #Root.BackdropCornerRadius}">
                <overlays:BlurBackdropControl x:Name="BackdropBlur"
                                               BlurRadius="{DynamicResource ImageDropOverlayBlurRadius}"
                                               Intensity="0"
                                               IsDynamic="{Binding #Root.IsActive}">
                    <overlays:BlurBackdropControl.Transitions>
                        <Transitions>
                            <DoubleTransition Duration="{StaticResource ImageDropOverlayFadeDuration}"
                                              Easing="{StaticResource ImageDropOverlayEasing}"
                                              Property="Intensity" />
                        </Transitions>
                    </overlays:BlurBackdropControl.Transitions>
                </overlays:BlurBackdropControl>
            </Border>

            <controls:ImageDropDashedBorderControl Margin="10"
                                                   StrokeColor="{DynamicResource ImageDropBorderColor}" />
        </Grid>

        <StackPanel x:Name="AnimatedContent"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Opacity="0"
                    RenderTransform="scale(0.97) translate(0px, 8px)"
                    RenderTransformOrigin="50%,50%"
                    Spacing="7">
            <StackPanel.Transitions>
                <Transitions>
                    <DoubleTransition Duration="{StaticResource ImageDropOverlayFadeDuration}"
                                      Easing="{StaticResource ImageDropOverlayEasing}"
                                      Property="Opacity" />
                    <TransformOperationsTransition Duration="0:0:0.22"
                                                   Easing="{StaticResource ImageDropOverlayEasing}"
                                                   Property="RenderTransform" />
                </Transitions>
            </StackPanel.Transitions>

            <Image Width="{Binding #Root.IconSize}"
                   Height="{Binding #Root.IconSize}"
                   HorizontalAlignment="Center"
                   RenderOptions.BitmapInterpolationMode="MediumQuality"
                   Source="avares://AtomicArt/Assets/DropIcon.png"
                   Stretch="Uniform">
                <Image.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      Color="#000000"
                                      OffsetX="0"
                                      OffsetY="14"
                                      Opacity="0.8" />
                </Image.Effect>
            </Image>

            <TextBlock HorizontalAlignment="Center"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource SukiText}"
                       Opacity="0.8"
                       Text="{x:Static resources:UiStrings.ImageDropLabel}" />
        </StackPanel>
    </Grid>
</UserControl>
