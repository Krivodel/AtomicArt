<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:overlays="using:AtomicArt.Desktop.Controls.Overlays"
             x:Class="AtomicArt.Desktop.Controls.Overlays.ModalOverlayControl"
             x:Name="Root"
             x:DataType="overlays:ModalOverlayControl">
    <Border Classes="overlay-panel modal-glass-panel">
        <Border Classes="modal-popup-layer">
            <Grid RowDefinitions="Auto,*">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Classes="overlay-title"
                               Text="{Binding #Root.Title}" />
                    <Button Grid.Column="1"
                            Classes="Icon close-action"
                            Command="{Binding #Root.CloseCommand}">
                        <PathIcon Data="{StaticResource AppCloseIcon}" />
                    </Button>
                </Grid>

                <ContentControl Grid.Row="1"
                                Content="{Binding #Root.Body}" />
            </Grid>
        </Border>
    </Border>
</UserControl>
