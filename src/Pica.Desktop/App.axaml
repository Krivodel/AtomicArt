<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:suki="using:SukiUI"
             x:Class="Pica.Desktop.App"
             RequestedThemeVariant="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <MergeResourceInclude Source="/Resources/Colors.axaml" />
                <MergeResourceInclude Source="/Resources/Brushes.axaml" />
                <MergeResourceInclude Source="/Resources/Dimensions.axaml" />
                <MergeResourceInclude Source="/Resources/Icons.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <suki:SukiTheme ThemeColor="Blue" />
        <StyleInclude Source="/Resources/ComboBoxStyles.axaml" />
        <StyleInclude Source="/Resources/TextStyles.axaml" />
        <StyleInclude Source="/Resources/ButtonStyles.axaml" />
        <StyleInclude Source="/Resources/Templates.axaml" />
    </Application.Styles>
</Application>
