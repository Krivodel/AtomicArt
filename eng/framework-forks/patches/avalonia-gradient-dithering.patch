+        private static SKRuntimeEffect CreateGradientDitherEffect()
+        {
+            const string shaderCode = """
+                uniform shader source;
+
+                half4 main(float2 position)
+                {
+                    half4 color = source.eval(position);
+                    float alpha = float(color.a);
+
+                    if (alpha <= 0.0 || alpha >= 1.0)
+                        return color;
+
+                    float noise = fract(52.9829189 * fract(dot(position, float2(0.06711056, 0.00583715)))) - 0.5;
+                    float ditheredAlpha = clamp(alpha + noise / 255.0, 0.0, 1.0);
+                    return half4(half3(float3(color.rgb) * ditheredAlpha / alpha), half(ditheredAlpha));
+                }
+                """;
+
+            return SKRuntimeEffect.CreateShader(shaderCode, out var errors)
+                ?? throw new InvalidOperationException($"Failed to create gradient dither effect: {errors}");
+        }
+
+        private static void SetGradientShader(SKPaint paint, SKShader shader)
+        {
+            var effect = s_gradientDitherEffect.Value;
+            var uniforms = new SKRuntimeEffectUniforms(effect);
+            var children = new SKRuntimeEffectChildren(effect)
+            {
+                ["source"] = shader
+            };
+
+            using var ditheredShader = effect.ToShader(uniforms, children, SKMatrix.CreateIdentity());
+            paint.Shader = ditheredShader;
+            paint.IsDither = true;
+        }
+
